    "build:tokens": "tsx ../../tooling/scripts/build-tokens.ts",
    "dev": "pnpm build:tokens && tsup --watch",
    "test": "vitest run src",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
