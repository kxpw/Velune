{
  "$schema": "https://velune.dev/schemas/tokens.schema.json",
  "colorSeeds": {
    "biscuit": "#AD7C4F",
    "celadon": "#587350",
    "clay": "#85662C",
    "oxblood": "#8A3B30",
    "neutral": "#8C8272"
  },
  "semantic": {
    "light": {
      "color-primary": "#AD7C4F",
      "color-primary-hover": "#96683F",
      "color-primary-active": "#7E5735",
      "color-primary-strong": "#96683F",
      "color-primary-strong-hover": "#7E5735",
      "color-primary-strong-active": "#6A4930",
      "color-success": "#587350",
      "color-warning": "#85662C",
      "color-error": "#8A3B30",
      "color-info": "var(--color-border-strong)",
      "color-canvas": "#FFF",
      "color-surface": "#FFF",
      "color-surface-raised": "#FFF",
      "color-surface-mist": "#F4F4F5",
      "color-text-primary": "#3A342B",
      "color-text-secondary": "#6E6556",
      "color-text-disabled": "#8C8272",
      "color-text-accent": "#7E5735",
      "color-border-default": "#E4E4E7",
      "color-border-strong": "#8C8272",
      "color-border-focus": "var(--color-primary)",
      "color-action-hover": "var(--color-surface-mist)",
      "color-action-active": "color-mix(in oklab, var(--color-text-primary) 8%, var(--color-surface-mist))",
      "color-focus-ring": "color-mix(in oklab, var(--color-primary) 45%, transparent)",
      "color-on-primary": "var(--color-surface)",
      "surface-highlight": "none",
      "surface-sheen": "0 0 0 transparent"
    },
    "dark": {
      "color-primary": "#C79A6B",
      "color-primary-hover": "#D3AB80",
      "color-primary-active": "#B9885C",
      "color-primary-strong": "#C79A6B",
      "color-primary-strong-hover": "#D3AB80",
      "color-primary-strong-active": "#B9885C",
      "color-success": "#9DB48A",
      "color-warning": "#C4A45E",
      "color-error": "#C97264",
      "color-info": "var(--color-border-strong)",
      "color-canvas": "#09090B",
      "color-surface": "#18181B",
      "color-surface-raised": "#27272A",
      "color-surface-mist": "#27272A",
      "color-text-primary": "#EFE9DC",
      "color-text-secondary": "#AFA491",
      "color-text-disabled": "#7C7260",
      "color-text-accent": "#C79A6B",
      "color-border-default": "#3F3F46",
      "color-border-strong": "#8C8272",
      "color-border-focus": "var(--color-primary)",
      "color-action-hover": "var(--color-surface-mist)",
      "color-action-active": "color-mix(in oklab, var(--color-text-primary) 10%, var(--color-surface-mist))",
      "color-focus-ring": "color-mix(in oklab, var(--color-primary) 45%, transparent)",
      "color-on-primary": "var(--color-canvas)",
      "surface-highlight": "none",
      "surface-sheen": "0 0 0 transparent"
    },
    "highContrast": {
      "color-primary": "{color-biscuit-800}",
      "color-primary-hover": "{color-biscuit-900}",
      "color-primary-active": "{color-biscuit-900}",
      "color-primary-strong": "{color-biscuit-800}",
      "color-primary-strong-hover": "{color-biscuit-900}",
      "color-primary-strong-active": "{color-biscuit-900}",
      "color-success": "{color-celadon-800}",
      "color-warning": "{color-clay-800}",
      "color-error": "{color-oxblood-800}",
      "color-info": "{color-neutral-800}",
      "color-canvas": "#FFF",
      "color-surface": "#FFF",
      "color-surface-raised": "#FFF",
      "color-surface-mist": "{color-neutral-100}",
      "color-text-primary": "{color-neutral-1000}",
      "color-text-secondary": "{color-neutral-800}",
      "color-text-disabled": "{color-neutral-700}",
      "color-text-accent": "{color-biscuit-800}",
      "color-border-default": "{color-neutral-1000}",
      "color-border-strong": "{color-neutral-1000}",
      "color-border-focus": "{color-celadon-800}",
      "color-action-hover": "color-mix(in oklab, var(--color-text-primary) 6%, transparent)",
      "color-action-active": "color-mix(in oklab, var(--color-text-primary) 10%, transparent)",
      "color-focus-ring": "var(--color-border-focus)",
      "color-on-primary": "var(--color-canvas)",
      "surface-highlight": "none",
      "surface-sheen": "0 0 0 transparent"
    }
  },
  "tokens": {
    "font": {
      "font-family-sans": "'Inter', 'Noto Sans SC', 'Velune Sans Fallback', system-ui, sans-serif",
      "font-family-serif": "'Source Serif 4', 'Noto Serif SC', 'Velune Serif Fallback', serif",
      "font-family-mono": "'JetBrains Mono', 'Velune Mono Fallback', monospace",
      "font-size-2xs": "11px",
      "font-size-xs": "12px",
      "font-size-sm": "14px",
      "font-size-md": "16px",
      "font-size-lg": "18px",
      "font-size-xl": "22px",
      "font-size-2xl": "26px",
      "font-size-3xl": "30px",
      "font-size-4xl": "34px",
      "line-height-tight": "1.4",
      "line-height-normal": "1.7",
      "line-height-body": "1.75",
      "line-height-relaxed": "1.8",
      "font-weight-light": "300",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-letter-spacing-cjk": "0"
    },
    "space": {
      "space-0": "0",
      "space-0.5": "2px",
      "space-1": "4px",
      "space-1.5": "6px",
      "space-2": "8px",
      "space-2.5": "10px",
      "space-3": "12px",
      "space-4": "16px",
      "space-5": "20px",
      "space-6": "24px",
      "space-7": "28px",
      "space-8": "32px",
      "space-9": "36px",
      "space-10": "40px",
      "space-11": "44px",
      "space-12": "48px",
      "space-16": "64px",
      "space-20": "80px",
      "space-24": "96px",
      "space-26": "104px"
    },
    "state": {
      "state-disabled-opacity": "0.48"
    },
    "radius": {
      "radius-none": "0",
      "radius-xs": "8px",
      "radius-sm": "10px",
      "radius-lg": "24px",
      "radius-full": "9999px"
    },
    "shadow": {
      "shadow-level-0": "none",
      "shadow-level-1": "0 2px 6px rgb(58 52 43 / 5%)",
      "shadow-level-2": "0 2px 6px rgb(58 52 43 / 5%), 0 18px 40px rgb(58 52 43 / 6%)",
      "shadow-level-3": "0 4px 12px rgb(58 52 43 / 5%), 0 28px 64px rgb(58 52 43 / 6%)"
    },
    "motion": {
      "duration-instant": "80ms",
      "duration-fast": "200ms",
      "duration-normal": "240ms",
      "duration-slow": "320ms",
      "duration-glaze": "500ms",
      "easing-standard": "cubic-bezier(0.22, 0.61, 0.36, 1)",
      "easing-glide": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "zIndex": {
      "z-base": "0",
      "z-dropdown": "1000",
      "z-sticky": "1100",
      "z-overlay": "1200",
      "z-modal": "1300",
      "z-popover": "1400",
      "z-toast": "1500"
    },
    "breakpoint": {
      "breakpoint-sm": "640px",
      "breakpoint-md": "768px",
      "breakpoint-lg": "1024px",
      "breakpoint-xl": "1280px",
      "breakpoint-2xl": "1536px"
    },
    "component": {
      "button-bg-secondary": "transparent",
      "button-bg-danger-active": "color-mix(in oklab, var(--color-text-primary) 16%, var(--color-error))",
      "focus-ring-width": "3px",
      "alert-bg-info": "color-mix(in oklab, var(--color-info) 6%, var(--color-surface))",
      "alert-bg-success": "color-mix(in oklab, var(--color-success) 10%, var(--color-surface))",
      "alert-bg-warning": "color-mix(in oklab, var(--color-warning) 14%, var(--color-surface))",
      "alert-bg-error": "color-mix(in oklab, var(--color-error) 6%, var(--color-surface))",
      "input-selection": "color-mix(in oklab, var(--color-primary) 22%, transparent)",
      "control-border-width": "1px",
      "checkbox-size-sm": "14px",
      "checkbox-size-lg": "18px",
      "checkbox-bg-invalid": "color-mix(in oklab, var(--color-error) 10%, var(--color-surface))",
      "checkbox-mark-size": "72%",
      "radio-dot-size": "40%",
      "switch-track-height-sm": "18px",
      "switch-thumb-size-lg": "22px",
      "switch-padding": "3px",
      "select-list-max-height": "240px",
      "spinner-duration": "900ms",
      "toast-min-width": "300px",
      "toast-max-width": "420px",
      "tooltip-max-width": "240px",
      "popover-max-width": "320px",
      "modal-overlay-bg": "color-mix(in oklab, var(--color-text-primary) 34%, transparent)",
      "modal-width-sm": "360px",
      "modal-width-md": "480px",
      "modal-width-lg": "640px",
      "drawer-overlay-bg": "color-mix(in oklab, var(--color-text-primary) 40%, transparent)",
      "drawer-size-sm": "280px",
      "sidebar-width": "15.5rem",
      "sidebar-width-icon": "4.75rem",
      "sidebar-width-mobile": "17.5rem",
      "table-row-selected-bg": "color-mix(in oklab, var(--color-primary) 10%, var(--color-surface))",
      "table-control-focus-bg": "color-mix(in oklab, var(--color-primary) 8%, transparent)",
      "table-sort-icon-opacity": "0.45",
      "table-sort-icon-inactive-opacity": "0.28",
      "table-loading-bg": "color-mix(in oklab, var(--color-surface) 82%, transparent)",
      "table-loading-content-opacity": "0.55",
      "table-virtual-height": "320px",
      "wizard-connector-color": "color-mix(in oklab, var(--color-text-primary) 10%, transparent)",
      "wizard-marker-bg-done": "color-mix(in oklab, var(--color-primary) 16%, transparent)",
      "datepicker-trigger-min-width": "12rem",
      "datepicker-day-bg-today": "color-mix(in oklab, var(--color-primary) 12%, transparent)",
      "progress-fill": "linear-gradient(to right, color-mix(in oklab, var(--color-primary) 45%, var(--color-surface)), var(--color-primary))",
      "skeleton-shimmer": "linear-gradient(90deg, transparent, color-mix(in oklab, var(--color-surface) 32%, transparent), transparent)",
      "relief-texture-opacity": "0.05",
      "relief-texture-opacity-hover": "0.16",
      "relief-texture-size": "520px auto",
      "relief-texture-drift-x": "18px",
      "focus-ring-invalid": "color-mix(in oklab, var(--color-error) 45%, transparent)"
    },
    "componentDark": {},
    "componentHighContrast": {
      "button-bg-secondary": "var(--color-surface)",
      "relief-texture-opacity": "0",
      "relief-texture-opacity-hover": "0",
      "progress-fill": "linear-gradient(to right, var(--color-primary), var(--color-primary))"
    }
  }
}
