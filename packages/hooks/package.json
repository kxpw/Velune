{
  "name": "@velune/hooks",
  "version": "0.0.0",
  "private": true,
  "description": "Velune shared React hooks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kxpw/Velune.git",
    "directory": "packages/hooks"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.1.1"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts"
}
