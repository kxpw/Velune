{
  "name": "velune-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "brace-expansion@5.0.5": "5.0.7",
      "esbuild": "0.28.1",
      "fast-uri@3.1.2": "3.1.4",
      "js-yaml@3.14.2": "3.15.0",
      "js-yaml@4.1.1": "4.3.0"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @velune/docs dev",
    "build": "pnpm -r --if-present run build",
    "build:tokens": "pnpm --filter @velune/react-internal build:tokens",
    "test": "pnpm --filter @velune/hooks build && pnpm -r --workspace-concurrency=1 --if-present run test",
    "lint": "eslint packages apps tooling --ext .ts,.tsx,.js,.mjs,.cjs && stylelint \"packages/**/*.css\" \"apps/**/*.css\"",
    "lint:architecture": "depcruise --config .dependency-cruiser.cjs packages apps tooling",
    "lint:components": "tsx tooling/scripts/check-component-standards.ts",
    "lint:tokens": "tsx tooling/scripts/check-visual-tokens.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "release": "pnpm build && pnpm package:check && changeset publish",
    "test:e2e": "pnpm --filter @velune/hooks build && pnpm --filter @velune/docs build && node tooling/scripts/run-e2e.mjs",
    "verify": "pnpm build:tokens && pnpm format:check && pnpm lint && pnpm lint:architecture && pnpm lint:components && pnpm lint:tokens && pnpm typecheck && pnpm test && pnpm build && pnpm rsc:check && pnpm docs:size:check && pnpm size:check && pnpm exports:check && pnpm package:check && pnpm performance:check",
    "verify:ci": "pnpm test:e2e && pnpm verify",
    "changeset": "changeset",
    "syncpack:list-mismatches": "syncpack lint",
    "size": "pnpm build && pnpm size:check",
    "size:check": "size-limit",
    "docs:llms": "tsx tooling/scripts/generate-llms.ts",
    "docs:size:check": "node tooling/scripts/check-docs-bundle.mjs",
    "performance:check": "node tooling/scripts/check-storybook-performance.mjs",
    "performance:interactions:check": "node tooling/scripts/check-storybook-performance.mjs --interactions-only",
    "performance:audit": "node tooling/scripts/check-storybook-performance.mjs --audit",
    "performance:audit:interactions": "node tooling/scripts/check-storybook-performance.mjs --audit --interactions-only",
    "exports:check": "node tooling/scripts/check-package-exports.mjs",
    "rsc:check": "node tooling/scripts/check-use-client.mjs",
    "package:check": "publint packages/velune && node tooling/scripts/check-packed-package.mjs",
    "storybook": "pnpm --filter @velune/storybook dev",
    "create:component": "tsx tooling/scripts/create-component.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.27.7",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.50.1",
    "@size-limit/esbuild": "12.1.0",
    "@size-limit/file": "12.1.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "dependency-cruiser": "16.10.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "playwright": "^1.50.1",
    "prettier": "^3.4.2",
    "publint": "^0.3.21",
    "size-limit": "12.1.0",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^37.0.0",
    "syncpack": "^15.3.2",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
